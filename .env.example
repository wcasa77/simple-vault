# Domain used by Caddy for automatic HTTPS (Let's Encrypt).
# Must have a public DNS A record pointing to this server before
# `docker compose up`, otherwise the ACME challenge will fail.
VAULT_DOMAIN=vault.yourdomain.com

# Comma-separated list of client IPs allowed to reach the vault API.
# Leave empty to accept requests from any IP (rate limiting still applies).
# Example: ALLOWED_IPS=203.0.113.7,198.51.100.22
ALLOWED_IPS=
